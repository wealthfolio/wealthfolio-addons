{
  "id": "swingfolio-addon",
  "name": "Swingfolio: Simple Stock Trading Tracker",
  "version": "3.6.1",
  "description": "A simple swing stock trading tracker with performance analytics and calendar views",
  "author": "Wealthfolio",
  "main": "dist/addon.js",
  "sdkVersion": "3.6.1",
  "minWealthfolioVersion": "3.6.1",
  "enabled": true,
  "contributes": {
    "routes": [
      { "id": "swingfolio", "path": "/addons/swingfolio" },
      { "id": "swingfolio-activities", "path": "/addons/swingfolio/activities" },
      { "id": "swingfolio-settings", "path": "/addons/swingfolio/settings" }
    ],
    "links": {
      "sidebar": [
        {
          "id": "swingfolio",
          "route": "swingfolio",
          "label": "Swingfolio",
          "icon": "chart-bar",
          "order": 150
        }
      ]
    }
  },
  "hostDependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@wealthfolio/addon-sdk": "^3.6.1",
    "@wealthfolio/ui": "^3.6.0",
    "date-fns": "^4.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "permissions": [
    {
      "category": "activities",
      "functions": ["search"],
      "purpose": "Access and manage trading activities for swing trading analysis"
    },
    {
      "category": "portfolio",
      "functions": ["getHoldings"],
      "purpose": "Access portfolio holdings to calculate unrealized P/L for open positions"
    },
    {
      "category": "currency",
      "functions": ["getAll"],
      "purpose": "Access to exchange rates and currency data"
    },
    {
      "category": "settings",
      "functions": ["get"],
      "purpose": "Access to application settings to get the base currency"
    }
  ]
}
