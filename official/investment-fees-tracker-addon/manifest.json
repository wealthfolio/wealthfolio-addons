{
  "id": "investment-fees-tracker-addon",
  "name": "Investment Fees Tracker",
  "version": "3.6.2",
  "description": "Track and analyze investment fees across your portfolio with detailed analytics and insights",
  "author": "Wealthfolio",
  "main": "dist/addon.js",
  "sdkVersion": "3.6.2",
  "minWealthfolioVersion": "3.6.2",
  "enabled": true,
  "contributes": {
    "routes": [{ "id": "investment-fees-tracker" }],
    "links": {
      "sidebar": [
        {
          "id": "investment-fees-tracker",
          "route": "investment-fees-tracker",
          "label": "Fee Tracker",
          "icon": "receipt",
          "order": 200
        }
      ]
    }
  },
  "hostDependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@wealthfolio/addon-sdk": "^3.6.2",
    "@wealthfolio/ui": "^3.6.2",
    "date-fns": "^4.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "permissions": [
    {
      "category": "portfolio",
      "functions": ["getHoldings"],
      "purpose": "Access portfolio holdings to analyze fees and expenses"
    },
    {
      "category": "activities",
      "functions": ["getAll"],
      "purpose": "Access transaction activities to track fee data"
    },
    {
      "category": "currency",
      "functions": ["getAll"],
      "purpose": "Access to exchange rates and currency data"
    },
    {
      "category": "settings",
      "functions": ["get"],
      "purpose": "Access settings to get base currency for fees calculation"
    },
    {
      "category": "ui",
      "functions": ["sidebar.addItem", "router.add", "onDisable"],
      "purpose": "Register the investment fees interface"
    }
  ]
}
